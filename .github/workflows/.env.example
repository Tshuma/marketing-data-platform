# ── PostgreSQL connection ────────────────────────────────────────────────────
# These must match the values in docker-compose.yml.
# If you change them here, change them there too.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketing
POSTGRES_USER=marketing
POSTGRES_PASSWORD=marketing

# ── Data directories ─────────────────────────────────────────────────────────
# Where fetch_olist.py writes Parquet files,
# and where ingest_batch.py reads them from.

DATA_DIR=data/processed

# ── Kaggle API (required for fetch_olist.py only) ────────────────────────────
# Get your token at https://www.kaggle.com/settings/account
# Alternatively place kaggle.json at ~/.kaggle/kaggle.json
# and leave these blank.

KAGGLE_USERNAME=
KAGGLE_KEY=